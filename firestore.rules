rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function accessId(poolId, uid) {
      return poolId + '_' + uid;
    }

    function hasPoolMembership(poolId, uid) {
      return exists(/databases/$(database)/documents/poolMembers/$(accessId(poolId, uid)));
    }

    function hasPoolMembershipAfter(poolId, uid) {
      return existsAfter(/databases/$(database)/documents/poolMembers/$(accessId(poolId, uid)));
    }

    function hasPoolAccess(poolId, uid) {
      return exists(/databases/$(database)/documents/poolAccess/$(accessId(poolId, uid))) ||
        hasPoolMembership(poolId, uid);
    }

    function hasPoolAccessAfter(poolId, uid) {
      return existsAfter(/databases/$(database)/documents/poolAccess/$(accessId(poolId, uid))) ||
        hasPoolMembershipAfter(poolId, uid);
    }

    function isActivePoolMember(poolId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activePoolId == poolId &&
        hasPoolAccess(poolId, request.auth.uid);
    }

    function activePoolId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activePoolId;
    }

    function validJoinSecret(poolId, secretId) {
      return secretId is string &&
        exists(/databases/$(database)/documents/poolJoinSecrets/$(secretId)) &&
        get(/databases/$(database)/documents/poolJoinSecrets/$(secretId)).data.poolId == poolId;
    }

    function userAfter(uid) {
      return getAfter(/databases/$(database)/documents/users/$(uid)).data;
    }

    // Bloqueio do palpite configuravel pelo admin (settings/app). Padrao: 1h
    // antes. Se desligado, o palpite fecha no inicio do jogo (kickoff).
    function lockOneHourBefore() {
      return !exists(/databases/$(database)/documents/settings/app) ||
        get(/databases/$(database)/documents/settings/app).data.get('lockOneHourBefore', true) != false;
    }

    function gameLockTime(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId)).data.startTime -
        (lockOneHourBefore() ? duration.value(1, 'h') : duration.value(0, 's'));
    }

    function isBeforeLock(gameId) {
      return request.time < gameLockTime(gameId);
    }

    function isValidPredictionScore(data) {
      return data.keys().hasAll(['homePrediction', 'awayPrediction']) &&
        data.homePrediction is int &&
        data.awayPrediction is int &&
        data.homePrediction >= 0 &&
        data.awayPrediction >= 0 &&
        data.homePrediction <= 30 &&
        data.awayPrediction <= 30;
    }

    function isPredictionOwnerById(predictionId, data) {
      return data.keys().hasAll(['gameId', 'userId']) &&
        data.gameId is string &&
        data.userId is string &&
        data.userId == request.auth.uid &&
        predictionId == data.gameId + '_' + request.auth.uid;
    }

    function validPoolPredictionId(poolPredictionId, data) {
      return data.keys().hasAll(['poolId', 'gameId', 'userId', 'sourcePredictionId']) &&
        data.poolId is string &&
        data.gameId is string &&
        data.userId is string &&
        data.userId == request.auth.uid &&
        data.sourcePredictionId == data.gameId + '_' + request.auth.uid &&
        poolPredictionId == data.poolId + '_' + data.gameId + '_' + request.auth.uid;
    }

    function sourcePredictionMatches(data) {
      let source = get(/databases/$(database)/documents/predictions/$(data.sourcePredictionId)).data;
      return source.userId == request.auth.uid &&
        source.gameId == data.gameId &&
        source.homePrediction == data.homePrediction &&
        source.awayPrediction == data.awayPrediction;
    }

    // ===== Usuarios =====
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      allow create: if isSelf(uid) &&
        request.resource.data.keys().hasOnly([
          'uid', 'username', 'displayName', 'role',
          'totalPoints', 'exactScores', 'correctResults',
          'predictionsCount', 'activePoolId', 'activePoolName',
          'lastPoolAccessAt', 'createdAt'
        ]) &&
        request.resource.data.uid == uid &&
        request.resource.data.role == 'user' &&
        request.resource.data.totalPoints == 0 &&
        request.resource.data.exactScores == 0 &&
        request.resource.data.correctResults == 0 &&
        request.resource.data.predictionsCount == 0 &&
        request.resource.data.activePoolId is string &&
        request.resource.data.activePoolName is string &&
        hasPoolAccessAfter(request.resource.data.activePoolId, uid);

      allow update: if isSelf(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'updatedAt'
        ]) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.username == resource.data.username &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.totalPoints == resource.data.totalPoints &&
        request.resource.data.exactScores == resource.data.exactScores &&
        request.resource.data.correctResults == resource.data.correctResults &&
        request.resource.data.predictionsCount == resource.data.predictionsCount &&
        request.resource.data.activePoolId == resource.data.activePoolId &&
        request.resource.data.activePoolName == resource.data.activePoolName;

      allow update: if isSelf(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'activePoolId', 'activePoolName', 'lastPoolAccessAt', 'updatedAt'
        ]) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.username == resource.data.username &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.totalPoints == resource.data.totalPoints &&
        request.resource.data.exactScores == resource.data.exactScores &&
        request.resource.data.correctResults == resource.data.correctResults &&
        request.resource.data.predictionsCount == resource.data.predictionsCount &&
        request.resource.data.activePoolId is string &&
        request.resource.data.activePoolName is string &&
        hasPoolAccessAfter(request.resource.data.activePoolId, uid);

      allow update, delete: if isAdmin();
    }

    // ===== Boloes =====
    match /pools/{poolId} {
      allow read: if isAdmin() || isActivePoolMember(poolId) || (isSignedIn() && hasPoolAccess(poolId, request.auth.uid));
      allow create, update, delete: if isAdmin();
    }

    match /poolJoinSecrets/{secretId} {
      allow read: if false;
      allow create, update, delete: if isAdmin();
    }

    match /poolAccess/{accessDocId} {
      // O id e sempre {poolId}_{uid}; o sufixo identifica o dono mesmo
      // quando o documento ainda nao existe (evita permission-denied no get).
      allow get: if isAdmin() ||
        (isSignedIn() && accessDocId.matches('.*_' + request.auth.uid));
      allow list: if isAdmin();

      allow create, update: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['poolId', 'uid', 'joinSecretId', 'updatedAt']) &&
        request.resource.data.poolId is string &&
        request.resource.data.uid == request.auth.uid &&
        accessDocId == accessId(request.resource.data.poolId, request.auth.uid) &&
        validJoinSecret(request.resource.data.poolId, request.resource.data.joinSecretId);

      allow delete: if isAdmin();
    }

    match /poolMembers/{memberDocId} {
      // O id e sempre {poolId}_{uid}; o sufixo identifica o dono mesmo
      // quando o documento ainda nao existe (evita permission-denied no get).
      allow get: if isAdmin() ||
        (isSignedIn() && memberDocId.matches('.*_' + request.auth.uid)) ||
        (isSignedIn() && resource != null && isActivePoolMember(resource.data.poolId));

      allow list: if isAdmin() || (
        isSignedIn() &&
        resource.data.uid == request.auth.uid
      ) || (
        isSignedIn() &&
        resource.data.poolId == activePoolId() &&
        hasPoolAccess(resource.data.poolId, request.auth.uid)
      );

      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'poolId', 'poolName', 'uid', 'username', 'displayName', 'role',
          'totalPoints', 'exactScores', 'correctResults', 'predictionsCount',
          'joinedAt', 'updatedAt'
        ]) &&
        request.resource.data.poolId is string &&
        request.resource.data.poolName is string &&
        request.resource.data.uid == request.auth.uid &&
        memberDocId == accessId(request.resource.data.poolId, request.auth.uid) &&
        hasPoolAccessAfter(request.resource.data.poolId, request.auth.uid) &&
        request.resource.data.username == userAfter(request.auth.uid).username &&
        request.resource.data.displayName == userAfter(request.auth.uid).displayName &&
        request.resource.data.role == userAfter(request.auth.uid).role &&
        // Entra com os pontos que o usuario ja tem nas stats globais (escritas
        // so por admin/recalc). Para um usuario novo essas stats sao 0.
        request.resource.data.totalPoints == userAfter(request.auth.uid).totalPoints &&
        request.resource.data.exactScores == userAfter(request.auth.uid).exactScores &&
        request.resource.data.correctResults == userAfter(request.auth.uid).correctResults &&
        request.resource.data.predictionsCount == userAfter(request.auth.uid).predictionsCount;

      allow update: if isSignedIn() &&
        resource.data.uid == request.auth.uid &&
        memberDocId == accessId(resource.data.poolId, request.auth.uid) &&
        request.resource.data.poolId == resource.data.poolId &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'poolName', 'username', 'displayName', 'role', 'updatedAt'
        ]) &&
        hasPoolAccessAfter(resource.data.poolId, request.auth.uid) &&
        request.resource.data.username == userAfter(request.auth.uid).username &&
        request.resource.data.displayName == userAfter(request.auth.uid).displayName &&
        request.resource.data.role == userAfter(request.auth.uid).role &&
        request.resource.data.totalPoints == resource.data.totalPoints &&
        request.resource.data.exactScores == resource.data.exactScores &&
        request.resource.data.correctResults == resource.data.correctResults &&
        request.resource.data.predictionsCount == resource.data.predictionsCount;

      allow update, delete: if isAdmin();
    }

    // ===== Reserva de usernames =====
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['uid', 'createdAt']) &&
        request.resource.data.uid == request.auth.uid;
      allow delete, update: if isAdmin();
    }

    // ===== Jogos =====
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== Palpites =====
    match /predictions/{predictionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.keys().hasAll([
          'userId', 'username', 'displayName', 'gameId',
          'homePrediction', 'awayPrediction', 'points',
          'exactScoreHit', 'resultHit', 'createdAt', 'updatedAt', 'lockedAt'
        ]) &&
        request.resource.data.keys().hasOnly([
          'userId', 'username', 'displayName', 'gameId',
          'homePrediction', 'awayPrediction', 'points',
          'exactScoreHit', 'resultHit', 'createdAt', 'updatedAt', 'lockedAt'
        ]) &&
        isPredictionOwnerById(predictionId, request.resource.data) &&
        request.resource.data.username == userAfter(request.auth.uid).username &&
        request.resource.data.displayName == userAfter(request.auth.uid).displayName &&
        isValidPredictionScore(request.resource.data) &&
        request.resource.data.points == 0 &&
        request.resource.data.exactScoreHit == false &&
        request.resource.data.resultHit == false &&
        request.resource.data.lockedAt == null &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        isBeforeLock(request.resource.data.gameId);

      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        isPredictionOwnerById(predictionId, resource.data) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.gameId == resource.data.gameId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'homePrediction', 'awayPrediction', 'username', 'displayName', 'updatedAt'
        ]) &&
        request.resource.data.username == userAfter(request.auth.uid).username &&
        request.resource.data.displayName == userAfter(request.auth.uid).displayName &&
        isValidPredictionScore(request.resource.data) &&
        request.resource.data.updatedAt == request.time &&
        isBeforeLock(resource.data.gameId);

      allow update, delete: if isAdmin();
    }

    // ===== Palpites visiveis por bolao =====
    match /poolPredictions/{poolPredictionId} {
      allow get, list: if isAdmin() || (
        isSignedIn() &&
        resource.data.poolId == activePoolId() &&
        hasPoolAccess(resource.data.poolId, request.auth.uid)
      );

      allow create, update: if isSignedIn() &&
        request.resource.data.keys().hasOnly([
          'poolId', 'poolName', 'sourcePredictionId',
          'userId', 'username', 'displayName', 'gameId',
          'homePrediction', 'awayPrediction', 'updatedAt'
        ]) &&
        validPoolPredictionId(poolPredictionId, request.resource.data) &&
        request.resource.data.poolName is string &&
        request.resource.data.username is string &&
        request.resource.data.displayName is string &&
        request.resource.data.username == userAfter(request.auth.uid).username &&
        request.resource.data.displayName == userAfter(request.auth.uid).displayName &&
        isValidPredictionScore(request.resource.data) &&
        hasPoolAccessAfter(request.resource.data.poolId, request.auth.uid) &&
        request.resource.data.updatedAt == request.time &&
        sourcePredictionMatches(request.resource.data);

      allow delete: if isAdmin();
    }

    // ===== Configuracoes do app =====
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ===== Logs de sincronizacao =====
    match /syncLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== Mata-Mata (chaveamento) =====
    // Prazo de edicao: 28/06/2026 15:00 America/Sao_Paulo = 18:00 UTC.
    function knockoutOpen() {
      return request.time < timestamp.date(2026, 6, 28) + duration.value(18, 'h');
    }

    match /knockoutPredictions/{uid} {
      // O dono e o admin sempre leem; os demais participantes so depois do
      // prazo (28/06 15:00), para ninguem copiar palpite antes do fechamento.
      allow read: if isSelf(uid) || isAdmin() || (isSignedIn() && !knockoutOpen());

      allow create, update: if isSelf(uid) &&
        knockoutOpen() &&
        request.resource.data.keys().hasOnly(['uid', 'picks', 'updatedAt']) &&
        request.resource.data.uid == uid &&
        request.resource.data.picks is map &&
        request.resource.data.updatedAt == request.time;

      allow delete: if isAdmin();
    }
  }
}
